{
  "regions": ["cdg1"],
  "crons": [
    {
      "path": "/api/cron/webinaire-reminders",
      "schedule": "*/15 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "popform-lake.vercel.app" }],
      "destination": "https://www.popform.fr/$1",
      "permanent": true
    }
  ]
}
